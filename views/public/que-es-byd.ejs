<%- include('../partials/public-head', {
    pageTitle: pagina.titulo + ' · BYD Monterrey',
    pageDescription: '¿Qué es BYD? El fabricante de vehículos eléctricos número uno del mundo. Tecnología, garantías y modelos disponibles en Monterrey.',
    active: 'byd'
}) %>

<section class="hero">
    <span class="hero-eyebrow"><i class="fas fa-circle-info"></i> Rincón BYD</span>
    <h1><%= pagina.titulo %></h1>
    <p>Todo lo que necesitas saber sobre BYD, la tecnología que está cambiando la industria.</p>
</section>

<section class="section" style="max-width: 920px;">
    <article style="background: white; border-radius: 18px; padding: 3rem; box-shadow: var(--shadow); border: 1px solid var(--line); font-size: 1.05rem; line-height: 1.7;">
        <style>
            article h2, article h3 { margin: 2rem 0 1rem; font-weight: 800; color: var(--ink); }
            article h2 { font-size: 1.6rem; }
            article h3 { font-size: 1.25rem; color: var(--green-dark); }
            article p { margin-bottom: 1rem; color: var(--ink-2); }
            article ul, article ol { margin: 1rem 0 1.5rem 1.5rem; }
            article ul li, article ol li { margin-bottom: 0.5rem; color: var(--ink-2); }
            article strong { color: var(--ink); }
            article a { color: var(--green); }
            article img { border-radius: 12px; margin: 1.5rem 0; max-width: 100%; }
            article blockquote { border-left: 4px solid var(--green); padding-left: 1.25rem; margin: 1.5rem 0; color: var(--muted); font-style: italic; }
        </style>
        <%- pagina.contenido_html %>
    </article>

    <% if (comentarios && comentarios.length > 0) { %>
        <div style="margin-top: 4rem;">
            <h2 style="text-align: center; font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem;">Lo que dicen quienes ya tienen un BYD</h2>
            <p style="text-align: center; color: var(--muted); margin-bottom: 2.5rem;">Testimonios reales de clientes de Salma</p>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem;">
                <% comentarios.forEach(function(c){ %>
                    <div style="background: white; border-radius: 14px; padding: 1.5rem; border: 1px solid var(--line); <% if (c.destacado) { %>border-color: var(--green); box-shadow: 0 0 0 1px var(--green);<% } %>">
                        <div style="color: var(--amber); margin-bottom: 0.75rem;">
                            <% for (let i = 0; i < (c.estrellas || 5); i++) { %><i class="fas fa-star"></i><% } %>
                        </div>
                        <p style="font-size: 0.98rem; margin-bottom: 1rem; color: var(--ink-2);">"<%= c.texto %>"</p>
                        <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                            <strong style="color: var(--ink);"><%= c.nombre %></strong>
                            <% if (c.modelo_byd) { %><span style="color: var(--green);"><i class="fas fa-car"></i> <%= c.modelo_byd %></span><% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
            <div style="text-align: center; margin-top: 2rem;">
                <a href="/comentarios" class="btn-wa" style="display: inline-flex; background: white; color: var(--green-dark); border: 1.5px solid var(--green);">
                    Ver todos los testimonios <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    <% } %>
</section>

<%- include('../partials/public-footer') %>
