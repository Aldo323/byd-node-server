<%- include('../partials/admin-shell', { title: 'Contenido' }) %>
<%- include('../partials/admin-sidebar', { active: 'contenido', pageTitle: 'Contenido editable' }) %>

<div class="card">
    <div class="card-head"><h2><i class="fas fa-pen-to-square"></i> Páginas editables</h2></div>
    <table>
        <thead><tr><th>Página</th><th>Slug (URL)</th><th>Actualizada</th><th></th></tr></thead>
        <tbody>
            <% paginas.forEach(function(p){ %>
                <tr>
                    <td><strong><%= p.titulo %></strong></td>
                    <td><code>/<%= p.slug %></code></td>
                    <td style="font-size: 0.88rem; color: var(--muted);">
                        <%= new Date(p.updated_at).toLocaleDateString('es-MX', {day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'}) %>
                    </td>
                    <td style="text-align: right;">
                        <a href="/admin/contenido/<%= p.slug %>" class="btn btn-primary btn-sm"><i class="fas fa-pen"></i> Editar</a>
                        <a href="/<%= p.slug %>" target="_blank" class="btn btn-secondary btn-sm"><i class="fas fa-up-right-from-square"></i></a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
</main></div></body></html>
