    <link rel="icon" type="image/png" href="/images/byd/bydicono.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/chat-widget.css">

    <style>
        :root {
            --green: #059669;
            --green-dark: #047857;
            --green-darker: #064e3b;
            --green-soft: #d1fae5;
            --green-mint: #ecfdf5;
            --blue: #0284c7;
            --red: #dc2626;
            --orange: #ea580c;
            --ink: #0f172a;
            --ink-2: #1e293b;
            --muted: #64748b;
            --muted-2: #94a3b8;
            --line: #e2e8f0;
            --bg: #f8fafc;
            --white: #ffffff;
            --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.06);
            --shadow: 0 4px 14px rgba(15, 23, 42, 0.08);
            --shadow-lg: 0 20px 50px rgba(15, 23, 42, 0.15);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }
        img { max-width: 100%; height: auto; display: block; }
        .tabular { font-variant-numeric: tabular-nums; }

        /* ============== NAV ============== */
        .nav {
            position: sticky; top: 0; z-index: 100;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--line);
            padding: 1rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            gap: 1rem;
        }
        .nav-logo { display: flex; align-items: center; gap: 0.6rem; font-weight: 800; color: var(--ink); text-decoration: none; }
        .nav-logo img { height: 32px; width: auto; }
        .nav-logo .ahorro-tag { background: var(--green); color: white; padding: 0.15rem 0.6rem; border-radius: 6px; font-size: 0.7rem; letter-spacing: 0.5px; }
        .nav-links { display: flex; gap: 1.75rem; list-style: none; align-items: center; }
        .nav-links a { color: var(--ink-2); text-decoration: none; font-size: 0.95rem; font-weight: 500; transition: color 0.2s; }
        .nav-links a:hover { color: var(--green); }
        .btn-wa {
            background: var(--green);
            color: white !important;
            padding: 0.65rem 1.25rem;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.92rem;
            text-decoration: none;
            cursor: pointer;
            display: inline-flex; align-items: center; gap: 0.5rem;
            transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
        }
        .btn-wa:hover { background: var(--green-dark); transform: translateY(-1px); box-shadow: var(--shadow); }
        .menu-toggle { display: none; background: none; border: none; font-size: 1.5rem; color: var(--ink); cursor: pointer; }
        @media (max-width: 900px) {
            .nav-links { display: none; }
            .menu-toggle { display: block; }
            .nav-links.open {
                display: flex; flex-direction: column; gap: 1rem;
                position: absolute; top: 100%; left: 0; right: 0;
                background: white; padding: 1.5rem; border-bottom: 1px solid var(--line);
            }
        }

        /* ============== HERO ============== */
        .hero {
            background: linear-gradient(135deg, #ecfdf5 0%, #f0f9ff 100%);
            padding: 3.5rem 1.5rem 5rem;
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute; top: -150px; right: -100px;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(5, 150, 105, 0.15), transparent 70%);
            border-radius: 50%;
            z-index: 0;
        }
        .hero-grid {
            max-width: 1200px; margin: 0 auto;
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 3.5rem; align-items: center;
            position: relative; z-index: 1;
        }
        @media (max-width: 950px) { .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

        .hero-eyebrow {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: var(--green-soft); color: var(--green-darker);
            padding: 0.4rem 0.9rem; border-radius: 999px;
            font-size: 0.85rem; font-weight: 600;
            margin-bottom: 1.5rem;
        }
        .hero h1 {
            font-size: clamp(2.1rem, 4.5vw, 3.6rem);
            font-weight: 900;
            line-height: 1.05;
            letter-spacing: -0.02em;
            margin-bottom: 1.25rem;
            color: var(--ink);
        }
        .hero h1 .accent { color: var(--green); }
        .hero h1 .strike {
            position: relative; color: var(--red); display: inline-block;
        }
        .hero h1 .strike::after {
            content: ''; position: absolute; left: -4%; right: -4%; top: 52%;
            height: 4px; background: var(--red); transform: rotate(-3deg);
            border-radius: 2px;
        }
        .hero-sub {
            font-size: 1.15rem; color: var(--muted); margin-bottom: 2rem;
            max-width: 520px;
        }
        .hero-badges {
            display: flex; flex-wrap: wrap; gap: 0.75rem;
            margin-bottom: 2rem;
        }
        .badge {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: white; border: 1px solid var(--line);
            padding: 0.55rem 0.95rem; border-radius: 10px;
            font-size: 0.88rem; font-weight: 500; color: var(--ink-2);
            box-shadow: var(--shadow-sm);
        }
        .badge i { color: var(--green); }

        /* ---- CALCULADORA MINI ---- */
        .calc-card {
            background: white;
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--line);
            padding: 1.75rem;
            position: relative;
        }
        .calc-head {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 1.25rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--line);
        }
        .calc-head h3 { font-size: 1.05rem; display: flex; align-items: center; gap: 0.5rem; }
        .calc-head h3 i { color: var(--green); }
        .calc-head .live {
            font-size: 0.7rem; color: var(--green); font-weight: 700;
            background: var(--green-soft); padding: 0.2rem 0.55rem; border-radius: 999px;
            display: flex; align-items: center; gap: 0.35rem;
        }
        .calc-head .live::before {
            content: ''; width: 6px; height: 6px; background: var(--green);
            border-radius: 50%; animation: pulse 1.6s infinite;
        }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

        .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; margin-bottom: 0.85rem; }
        @media (max-width: 480px) { .calc-row { grid-template-columns: 1fr; } }
        .calc-field label {
            display: block; font-size: 0.78rem; font-weight: 600;
            color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 0.35rem;
        }
        .calc-field-wrap {
            position: relative;
            background: var(--bg);
            border: 1.5px solid var(--line);
            border-radius: 10px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        .calc-field-wrap:focus-within { border-color: var(--green); box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.12); }
        .calc-field-wrap input,
        .calc-field-wrap select {
            width: 100%;
            background: transparent;
            border: none;
            padding: 0.7rem 0.9rem;
            font-size: 1rem;
            font-weight: 600;
            color: var(--ink);
            font-family: inherit;
            outline: none;
            -moz-appearance: textfield;
        }
        .calc-field-wrap input::-webkit-outer-spin-button,
        .calc-field-wrap input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .calc-field-wrap .suffix {
            position: absolute; right: 0.9rem; top: 50%; transform: translateY(-50%);
            color: var(--muted); font-size: 0.85rem; pointer-events: none;
        }

        .calc-result {
            background: linear-gradient(135deg, var(--green-darker), var(--green));
            border-radius: 14px;
            padding: 1.25rem;
            margin: 1.25rem 0;
            color: white;
            position: relative;
            overflow: hidden;
        }
        .calc-result::after {
            content: ''; position: absolute; right: -30px; top: -30px;
            width: 140px; height: 140px;
            background: radial-gradient(circle, rgba(255,255,255,0.1), transparent 70%);
            border-radius: 50%;
        }
        .calc-result-label { font-size: 0.78rem; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 0.35rem; }
        .calc-result-main { font-size: 2.4rem; font-weight: 900; line-height: 1; letter-spacing: -0.02em; }
        .calc-result-main small { font-size: 1rem; opacity: 0.85; font-weight: 500; }
        .calc-result-row {
            display: flex; gap: 1.5rem; margin-top: 1rem; padding-top: 1rem;
            border-top: 1px solid rgba(255,255,255,0.18);
            font-size: 0.92rem;
        }
        .calc-result-row > div { flex: 1; }
        .calc-result-row strong { display: block; font-size: 1.2rem; font-weight: 800; }

        .calc-actions { display: flex; gap: 0.6rem; flex-wrap: wrap; }
        .calc-actions a {
            flex: 1; min-width: 140px;
            padding: 0.85rem 1rem;
            text-align: center;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.92rem;
            transition: transform 0.15s, box-shadow 0.15s;
        }
        .calc-actions a:hover { transform: translateY(-1px); box-shadow: var(--shadow); }
        .calc-actions .primary { background: var(--green); color: white; }
        .calc-actions .primary:hover { background: var(--green-dark); }
        .calc-actions .secondary {
            background: white; color: var(--green-dark);
            border: 1.5px solid var(--green);
        }

        /* ============== SECCIONES ============== */
        .section { padding: 5rem 1.5rem; max-width: 1200px; margin: 0 auto; }
        .section-narrow { max-width: 980px; }
        .eyebrow { color: var(--green); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 0.75rem; }
        .section h2 { font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 800; line-height: 1.15; margin-bottom: 1rem; letter-spacing: -0.02em; }
        .section .lead { color: var(--muted); font-size: 1.1rem; max-width: 680px; }
        .section-head { margin-bottom: 3rem; }
        .section-head.center { text-align: center; }
        .section-head.center .lead { margin: 0 auto; }

        /* ---- Razones del ahorro ---- */
        .reasons {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.25rem;
        }
        .reason {
            background: white; border: 1px solid var(--line);
            border-radius: 16px; padding: 1.75rem;
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        }
        .reason:hover { transform: translateY(-4px); box-shadow: var(--shadow); border-color: var(--green); }
        .reason-icon {
            width: 48px; height: 48px; border-radius: 12px;
            background: var(--green-mint); color: var(--green);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; margin-bottom: 1.1rem;
        }
        .reason h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; }
        .reason p { font-size: 0.95rem; color: var(--muted); }
        .reason .savings-tag {
            display: inline-block; margin-top: 0.85rem;
            background: var(--green-soft); color: var(--green-darker);
            padding: 0.25rem 0.65rem; border-radius: 6px;
            font-size: 0.8rem; font-weight: 700;
        }

        /* ---- Comparativa ---- */
        .compare {
            background: var(--ink);
            color: white;
            padding: 5rem 1.5rem;
        }
        .compare-inner { max-width: 1100px; margin: 0 auto; }
        .compare h2 { color: white; }
        .compare .lead { color: var(--muted-2); }
        .compare-grid {
            display: grid; grid-template-columns: 1fr 1fr 1fr;
            gap: 1.5rem; margin-top: 3rem;
            align-items: end;
        }
        @media (max-width: 900px) { .compare-grid { grid-template-columns: 1fr; } }
        .compare-card {
            background: var(--ink-2);
            border: 1px solid #334155;
            border-radius: 18px;
            padding: 2rem;
            position: relative;
        }
        .compare-card.gas { border-color: rgba(220, 38, 38, 0.4); }
        .compare-card.byd { border-color: rgba(5, 150, 105, 0.5); background: linear-gradient(180deg, rgba(5,150,105,0.12), var(--ink-2)); }
        .compare-card.saving { border-color: var(--green); background: linear-gradient(135deg, var(--green-darker), var(--green)); }
        .compare-card .tag {
            position: absolute; top: -12px; left: 1.5rem;
            background: var(--green); color: white;
            padding: 0.3rem 0.8rem; border-radius: 6px;
            font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;
        }
        .compare-card.gas .tag { background: var(--red); }
        .compare-card h4 { font-size: 1rem; color: var(--muted-2); margin-bottom: 0.5rem; font-weight: 500; }
        .compare-card.saving h4 { color: rgba(255,255,255,0.9); }
        .compare-card .big {
            font-size: 2.6rem; font-weight: 900;
            letter-spacing: -0.02em; line-height: 1;
            margin-bottom: 0.5rem;
        }
        .compare-card .big small { font-size: 1rem; font-weight: 500; opacity: 0.7; }
        .compare-card.gas .big { color: #fca5a5; }
        .compare-card.byd .big { color: #6ee7b7; }
        .compare-card .desc { font-size: 0.9rem; color: var(--muted-2); }
        .compare-card.saving .desc { color: rgba(255,255,255,0.85); }
        .compare-card ul { list-style: none; margin-top: 1rem; }
        .compare-card ul li { padding: 0.35rem 0; font-size: 0.92rem; display: flex; align-items: center; gap: 0.5rem; }
        .compare-card ul li i { font-size: 0.8rem; }
        .compare-card.gas ul li i { color: #fca5a5; }
        .compare-card.byd ul li i { color: #6ee7b7; }

        .compare-timeline {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem; margin-top: 3rem;
        }
        .timeline-item {
            background: rgba(255,255,255,0.04);
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 1.25rem;
            text-align: center;
        }
        .timeline-item .period { font-size: 0.78rem; color: var(--muted-2); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.35rem; }
        .timeline-item .amount { font-size: 1.55rem; font-weight: 800; color: #6ee7b7; }

        /* ---- Casos ---- */
        .cases {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }
        .case-card {
            background: white; border: 1px solid var(--line);
            border-radius: 18px; padding: 2rem;
            display: flex; flex-direction: column; gap: 0.85rem;
        }
        .case-avatar {
            width: 54px; height: 54px; border-radius: 50%;
            background: var(--green-mint); color: var(--green);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
        }
        .case-name { font-weight: 700; font-size: 1.1rem; }
        .case-meta { color: var(--muted); font-size: 0.9rem; }
        .case-savings {
            background: var(--green-mint);
            border-radius: 10px;
            padding: 0.85rem 1rem;
            margin-top: auto;
        }
        .case-savings .num { font-size: 1.6rem; font-weight: 900; color: var(--green-darker); }
        .case-savings .lbl { font-size: 0.82rem; color: var(--green-dark); }

        /* ---- Modelos slim ---- */
        .models-strip {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
        }
        .model-pill {
            background: white; border: 1px solid var(--line);
            border-radius: 16px; padding: 1.5rem;
            text-decoration: none; color: var(--ink);
            display: block; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        }
        .model-pill:hover { transform: translateY(-3px); box-shadow: var(--shadow); border-color: var(--green); }
        .model-pill img { height: 100px; object-fit: contain; margin: 0 auto 0.85rem; }
        .model-pill .nm { font-weight: 800; font-size: 1.05rem; margin-bottom: 0.25rem; }
        .model-pill .ty {
            display: inline-block;
            font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;
            padding: 0.18rem 0.55rem; border-radius: 6px;
            margin-bottom: 0.6rem;
        }
        .model-pill .ty.electric { background: #dbeafe; color: #1e40af; }
        .model-pill .ty.hybrid { background: #fef3c7; color: #92400e; }
        .model-pill .save { font-weight: 700; color: var(--green-dark); font-size: 0.95rem; }

        /* ---- CTA ---- */
        .cta-final {
            background: linear-gradient(135deg, var(--green-darker), var(--green));
            color: white; padding: 5rem 1.5rem; text-align: center;
            border-radius: 0;
        }
        .cta-final h2 { color: white; font-size: clamp(1.8rem, 3.5vw, 2.5rem); margin-bottom: 1rem; }
        .cta-final p { color: rgba(255,255,255,0.9); max-width: 600px; margin: 0 auto 2rem; font-size: 1.1rem; }
        .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
        .cta-buttons a {
            padding: 1rem 2rem; border-radius: 12px;
            font-weight: 700; text-decoration: none; font-size: 1rem;
            transition: transform 0.15s, box-shadow 0.15s;
            display: inline-flex; align-items: center; gap: 0.5rem;
        }
        .cta-buttons a:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,0.2); }
        .cta-buttons .wa { background: white; color: var(--green-darker); }
        .cta-buttons .calc { background: rgba(255,255,255,0.12); color: white; border: 1.5px solid rgba(255,255,255,0.4); }

        /* ---- FAQ leve ---- */
        .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        @media (max-width: 800px) { .faq-grid { grid-template-columns: 1fr; } }
        .faq-item { background: white; border: 1px solid var(--line); border-radius: 14px; padding: 1.5rem; }
        .faq-item h4 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; }
        .faq-item h4 i { color: var(--green); }
        .faq-item p { color: var(--muted); font-size: 0.95rem; }

        /* ---- DASHBOARD MOCKUP RESPONSIVE ---- */
        @media (max-width: 850px) {
            .dash-grid { grid-template-columns: 1fr !important; }
        }
        @media (max-width: 500px) {
            #dashboard-real h2 { font-size: 1.6rem !important; }
        }

        /* ---- FOOTER ---- */
        footer {
            background: var(--ink);
            color: var(--muted-2);
            padding: 3rem 1.5rem 2rem;
            text-align: center;
            font-size: 0.9rem;
        }
        footer a { color: #6ee7b7; text-decoration: none; }
        footer .foot-row { max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: center; }
        footer .foot-row a { color: var(--muted-2); }
        footer .foot-row a:hover { color: white; }
        footer .disclaimer { margin-top: 1.5rem; font-size: 0.78rem; opacity: 0.7; max-width: 700px; margin-left: auto; margin-right: auto; }
    </style>
</head>
<body>

<!-- ============== NAV ============== -->
<nav class="nav">
    <a href="/" class="nav-logo">
        <img src="/images/byd/BYD-Logo.png" alt="BYD">
        <span class="ahorro-tag">AHORRO</span>
    </a>
    <ul class="nav-links" id="navLinks">
        <li><a href="#calculadora">Ahorro</a></li>
        <li><a href="/entregas">Entregas</a></li>
        <li><a href="/que-es-byd">¿Qué es BYD?</a></li>
        <li><a href="/comentarios">Testimonios</a></li>
        <li><a href="/calculatusahorros">Cálculo detallado</a></li>
    </ul>
    <a href="#" class="btn-wa" onclick="openWhatsApp(); return false;">
        <i class="fab fa-whatsapp"></i> Hablar con Salma
    </a>
    <button class="menu-toggle" id="menuToggle" aria-label="Menú"><i class="fas fa-bars"></i></button>
</nav>

<!-- ============== HERO + CALCULADORA ============== -->
<section class="hero" id="calculadora">
    <div class="hero-grid">
        <div>
            <span class="hero-eyebrow"><i class="fas fa-check-circle"></i> Datos reales · Dashboard BYD King PHEV</span>
            <h1>Mi BYD King ya ahorró <span class="accent">$21,236</span> reales en gasolina.</h1>
            <p class="hero-sub">No es promesa, son <strong>17,220 km recorridos</strong> y solo <strong>308 L de combustible</strong> consumidos según el dashboard del vehículo. Calcula abajo cuánto puede ahorrar el tuyo.</p>
            <div class="hero-badges">
                <span class="badge"><i class="fas fa-road"></i> 17,220 km recorridos</span>
                <span class="badge"><i class="fas fa-gas-pump"></i> Solo 1.8 L/100 km</span>
                <span class="badge"><i class="fas fa-bolt"></i> 5.9 kW·h/100 km</span>
            </div>
        </div>

        <!-- Calculadora mini -->
        <div class="calc-card" id="miniCalc">
            <div class="calc-head">
                <h3><i class="fas fa-calculator"></i> Calculadora rápida de ahorro</h3>
                <span class="live">EN VIVO</span>
            </div>

            <div class="calc-row">
                <div class="calc-field">
                    <label for="kmMes">¿Km que manejas al mes?</label>
                    <div class="calc-field-wrap">
                        <input type="number" id="kmMes" value="1500" min="100" max="20000" step="100">
                        <span class="suffix">km</span>
                    </div>
                </div>
                <div class="calc-field">
                    <label for="rendimiento">Rendimiento actual</label>
                    <div class="calc-field-wrap">
                        <input type="number" id="rendimiento" value="12" min="4" max="30" step="0.5">
                        <span class="suffix">km/L</span>
                    </div>
                </div>
            </div>

            <div class="calc-row">
                <div class="calc-field">
                    <label for="tipoGas">Tipo de gasolina</label>
                    <div class="calc-field-wrap">
                        <select id="tipoGas">
                            <option value="magna" data-price="<%= gasPrices.magna %>">Magna · $<%= gasPrices.magna %>/L</option>
                            <option value="premium" data-price="<%= gasPrices.premium %>">Premium · $<%= gasPrices.premium %>/L</option>
                        </select>
                    </div>
                </div>
                <div class="calc-field">
                    <label for="tipoBYD">Tipo de BYD</label>
                    <div class="calc-field-wrap">
                        <select id="tipoBYD">
                            <option value="electrico">100% eléctrico</option>
                            <option value="phev">Híbrido enchufable</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="calc-result">
                <div class="calc-result-label">AHORRO ESTIMADO POR MES</div>
                <div class="calc-result-main tabular">$<span id="ahorroMes">0</span><small>/mes</small></div>
                <div class="calc-result-row">
                    <div>
                        <span style="opacity:0.85; font-size:0.82rem;">Al año</span>
                        <strong class="tabular">$<span id="ahorroAnio">0</span></strong>
                    </div>
                    <div>
                        <span style="opacity:0.85; font-size:0.82rem;">En 5 años</span>
                        <strong class="tabular">$<span id="ahorro5">0</span></strong>
                    </div>
                </div>
            </div>

            <div class="calc-actions">
                <a href="/calculatusahorros" class="primary"><i class="fas fa-calculator"></i> Cálculo detallado</a>
                <a href="#" class="secondary" onclick="openWhatsAppConAhorro(); return false;"><i class="fab fa-whatsapp"></i> Cotizar</a>
            </div>
        </div>
    </div>
</section>

<!-- ============== DASHBOARD REAL DEL KING ============== -->
<section style="background: linear-gradient(180deg, var(--white) 0%, var(--green-mint) 100%); padding: 5rem 1.5rem;" id="dashboard-real">
    <div style="max-width: 1200px; margin: 0 auto;">
        <div class="section-head center">
            <div class="eyebrow"><i class="fas fa-tv"></i> Pantalla del vehículo · Consumo de Energía</div>
            <h2>Estos no son números inventados.<br>Este es el dashboard de <span style="color: var(--green);">mi BYD King</span>.</h2>
            <p class="lead">Cada métrica que ves aquí abajo viene directo de la pantalla "Consumo de Energía" del vehículo. Tú mismo puedes ver el dashboard cuando agendes tu prueba de manejo.</p>
        </div>

        <!-- Replica del dashboard -->
        <div style="background: #0a0e1a; border-radius: 24px; padding: 1.5rem; box-shadow: var(--shadow-lg); border: 1px solid #1c2540; max-width: 1100px; margin: 0 auto;">
            <!-- Top bar -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 1rem; margin-bottom: 1rem;">
                <div style="display: flex; gap: 0.5rem;">
                    <span style="background: linear-gradient(135deg, var(--green), var(--blue)); color: white; padding: 0.55rem 1.1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 700;">Consumo de Energía</span>
                    <span style="color: #94a0c0; padding: 0.55rem 1.1rem; font-size: 0.85rem;">Gestión de energía</span>
                    <span style="color: #94a0c0; padding: 0.55rem 1.1rem; font-size: 0.85rem; display: none;" class="dash-tab-extra">Carga y Descarga</span>
                </div>
                <div style="color: #94a0c0; display: flex; gap: 0.8rem; font-size: 1rem;">
                    <i class="fas fa-map-marker-alt"></i>
                    <i class="fab fa-bluetooth-b"></i>
                    <i class="fas fa-signal"></i>
                    <i class="fas fa-bell"></i>
                    <i class="fas fa-user"></i>
                </div>
            </div>

            <!-- Dashboard panels -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;" class="dash-grid">
                <!-- Panel izquierdo: Datos generales -->
                <div style="background: #161d33; border-radius: 16px; padding: 1.5rem; color: white;">
                    <div style="color: #94a0c0; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem;">Datos generales</div>

                    <div style="background: #1c2540; border-radius: 12px; padding: 1rem; margin-bottom: 1rem;">
                        <div style="color: #94a0c0; font-size: 0.75rem; margin-bottom: 0.25rem;">ODÓMETRO</div>
                        <div style="font-size: 1.85rem; font-weight: 800; color: white;" class="tabular">17,220.5 <span style="font-size: 0.9rem; font-weight: 500; color: #94a0c0;">km</span></div>
                    </div>

                    <div style="color: #94a0c0; font-size: 0.75rem; margin-bottom: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px;">Consumo promedio</div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-bottom: 1.1rem;">
                        <div style="background: #1c2540; border-radius: 10px; padding: 0.85rem;">
                            <div style="display: flex; align-items: center; gap: 0.4rem; color: #fb923c; margin-bottom: 0.35rem;">
                                <i class="fas fa-gas-pump"></i>
                                <span style="font-size: 0.72rem; text-transform: uppercase;">Combustible</span>
                            </div>
                            <div style="font-size: 1.35rem; font-weight: 800;" class="tabular">1.8<span style="font-size: 0.78rem; color: #94a0c0; font-weight: 500;"> L/100 km</span></div>
                        </div>
                        <div style="background: #1c2540; border-radius: 10px; padding: 0.85rem;">
                            <div style="display: flex; align-items: center; gap: 0.4rem; color: #38bdf8; margin-bottom: 0.35rem;">
                                <i class="fas fa-bolt"></i>
                                <span style="font-size: 0.72rem; text-transform: uppercase;">Electricidad</span>
                            </div>
                            <div style="font-size: 1.35rem; font-weight: 800;" class="tabular">5.9<span style="font-size: 0.78rem; color: #94a0c0; font-weight: 500;"> kW·h/100</span></div>
                        </div>
                    </div>

                    <div style="background: linear-gradient(135deg, rgba(5,150,105,0.15), rgba(56,189,248,0.15)); border: 1px solid rgba(5,150,105,0.4); border-radius: 12px; padding: 0.95rem; margin-bottom: 1rem;">
                        <div style="color: #6ee7b7; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.25rem;"><i class="fas fa-route"></i> Autonomía actual</div>
                        <div style="font-size: 1.85rem; font-weight: 800;" class="tabular">814.0 <span style="font-size: 0.9rem; color: #94a0c0;">km</span></div>
                    </div>

                    <div style="border-top: 1px solid #243056; padding-top: 1rem; display: grid; gap: 0.55rem;">
                        <div style="display: flex; justify-content: space-between; font-size: 0.88rem;">
                            <span style="color: #94a0c0;">Total combustible</span>
                            <strong class="tabular">308.2 L</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.88rem;">
                            <span style="color: #94a0c0;">Carga externa</span>
                            <strong class="tabular">1,582.9 kW·h</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.88rem;">
                            <span style="color: #94a0c0;">Tiempo conducción</span>
                            <strong class="tabular">23.0 h</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.88rem;">
                            <span style="color: #94a0c0;">Velocidad media</span>
                            <strong class="tabular">23 km/h</strong>
                        </div>
                    </div>
                </div>

                <!-- Panel derecho: Gráfico -->
                <div style="background: #161d33; border-radius: 16px; padding: 1.5rem; color: white;">
                    <div style="color: #94a0c0; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem;">Gráfico de Consumo</div>

                    <div style="display: flex; gap: 0.4rem; margin-bottom: 1rem; flex-wrap: wrap;">
                        <span style="background: #1c2540; padding: 0.35rem 0.85rem; border-radius: 999px; font-size: 0.78rem; color: #94a0c0;">Electricidad</span>
                        <span style="background: #1c2540; padding: 0.35rem 0.85rem; border-radius: 999px; font-size: 0.78rem; color: #94a0c0;">Combustible</span>
                        <span style="background: var(--green); color: white; padding: 0.35rem 0.85rem; border-radius: 999px; font-size: 0.78rem; font-weight: 700;">● Todos</span>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-bottom: 1rem;">
                        <div style="background: #1c2540; border-radius: 10px; padding: 0.7rem;">
                            <div style="color: #38bdf8; font-size: 0.7rem; text-transform: uppercase;">Eléctrico medio</div>
                            <div style="font-size: 1.15rem; font-weight: 800;" class="tabular">3.7<span style="font-size: 0.7rem; color: #94a0c0; font-weight: 500;"> kW·h/100</span></div>
                        </div>
                        <div style="background: #1c2540; border-radius: 10px; padding: 0.7rem;">
                            <div style="color: #fb923c; font-size: 0.7rem; text-transform: uppercase;">AFC</div>
                            <div style="font-size: 1.15rem; font-weight: 800;" class="tabular">2.2<span style="font-size: 0.7rem; color: #94a0c0; font-weight: 500;"> L/100 km</span></div>
                        </div>
                    </div>

                    <!-- SVG grafico -->
                    <div style="background: #0a0e1a; border-radius: 10px; padding: 0.85rem; height: 200px;">
                        <svg viewBox="0 0 500 180" width="100%" height="100%" preserveAspectRatio="none">
                            <defs>
                                <linearGradient id="fGRD" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#fb923c" stop-opacity="0.45"/>
                                    <stop offset="100%" stop-color="#fb923c" stop-opacity="0"/>
                                </linearGradient>
                                <linearGradient id="eGRD" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.45"/>
                                    <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                            <g stroke="#1c2540" stroke-dasharray="2 4">
                                <line x1="35" y1="40" x2="465" y2="40"/>
                                <line x1="35" y1="90" x2="465" y2="90"/>
                                <line x1="35" y1="140" x2="465" y2="140"/>
                            </g>
                            <line x1="35" y1="15" x2="35" y2="160" stroke="#243056"/>
                            <line x1="465" y1="15" x2="465" y2="160" stroke="#243056"/>
                            <line x1="35" y1="160" x2="465" y2="160" stroke="#243056"/>
                            <g fill="#94a0c0" font-size="9">
                                <text x="5" y="19">40</text><text x="5" y="44">30</text><text x="5" y="94">20</text><text x="5" y="144">10</text><text x="10" y="164">0</text>
                                <text x="470" y="19">20</text><text x="470" y="44">15</text><text x="470" y="94">10</text><text x="470" y="144">5</text><text x="470" y="164">0</text>
                            </g>
                            <!-- Combustible (naranja) -->
                            <path d="M35,155 L75,140 L115,135 L155,142 L195,128 L235,140 L275,118 L315,138 L355,115 L395,125 L435,118 L465,122 L465,160 L35,160 Z" fill="url(#fGRD)"/>
                            <path d="M35,155 L75,140 L115,135 L155,142 L195,128 L235,140 L275,118 L315,138 L355,115 L395,125 L435,118 L465,122" fill="none" stroke="#fb923c" stroke-width="1.8"/>
                            <!-- Electricidad (azul) -->
                            <path d="M35,130 L75,115 L115,108 L155,118 L195,98 L235,112 L275,90 L315,105 L355,85 L395,100 L435,92 L465,95 L465,160 L35,160 Z" fill="url(#eGRD)"/>
                            <path d="M35,130 L75,115 L115,108 L155,118 L195,98 L235,112 L275,90 L315,105 L355,85 L395,100 L435,92 L465,95" fill="none" stroke="#38bdf8" stroke-width="1.8"/>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Barra inferior -->
            <div style="display: flex; gap: 1.25rem; padding: 0.85rem 1rem; margin-top: 1rem; overflow-x: auto; color: #94a0c0; font-size: 0.85rem; border-top: 1px solid #1c2540; padding-top: 1rem;">
                <span style="white-space: nowrap;"><i class="fas fa-thermometer-half" style="color: var(--green);"></i> 25°C</span>
                <span style="white-space: nowrap;"><i class="fas fa-cog"></i></span>
                <span style="white-space: nowrap;"><i class="fas fa-couch" style="color: var(--green);"></i> ON</span>
                <span style="white-space: nowrap;"><i class="fas fa-car-side"></i> Modo</span>
                <span style="white-space: nowrap;"><i class="fas fa-gas-pump"></i></span>
                <span style="white-space: nowrap;"><i class="fas fa-car"></i></span>
                <span style="white-space: nowrap;">1 ocupante</span>
                <span style="white-space: nowrap;"><i class="fas fa-play"></i></span>
                <span style="white-space: nowrap;"><i class="fas fa-pause"></i></span>
                <span style="white-space: nowrap;"><i class="fas fa-th-large"></i></span>
            </div>
        </div>

        <!-- Lo que cuenta el dashboard -->
        <div style="margin-top: 3rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; max-width: 1100px; margin-left: auto; margin-right: auto;">
            <div style="background: white; border: 1px solid var(--line); border-radius: 14px; padding: 1.5rem; text-align: center; box-shadow: var(--shadow-sm);">
                <div style="color: var(--muted); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">Eficiencia combinada</div>
                <div style="font-size: 2rem; font-weight: 900; color: var(--green);" class="tabular">55.9 <small style="font-size: 1rem; color: var(--muted); font-weight: 500;">km/L</small></div>
                <div style="font-size: 0.85rem; color: var(--muted); margin-top: 0.35rem;">vs ~12 km/L de un auto gasolina típico</div>
            </div>
            <div style="background: white; border: 1px solid var(--line); border-radius: 14px; padding: 1.5rem; text-align: center; box-shadow: var(--shadow-sm);">
                <div style="color: var(--muted); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">Costo por km</div>
                <div style="font-size: 2rem; font-weight: 900; color: var(--green);" class="tabular">$0.75</div>
                <div style="font-size: 0.85rem; color: var(--muted); margin-top: 0.35rem;">vs $1.98 con gasolina</div>
            </div>
            <div style="background: white; border: 1px solid var(--line); border-radius: 14px; padding: 1.5rem; text-align: center; box-shadow: var(--shadow-sm);">
                <div style="color: var(--muted); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">% Eléctrico</div>
                <div style="font-size: 2rem; font-weight: 900; color: var(--green);" class="tabular">~76%</div>
                <div style="font-size: 0.85rem; color: var(--muted); margin-top: 0.35rem;">del recorrido sin gasolina</div>
            </div>
            <div style="background: linear-gradient(135deg, var(--green-darker), var(--green)); color: white; border-radius: 14px; padding: 1.5rem; text-align: center; box-shadow: var(--shadow);">
                <div style="opacity: 0.9; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem;">Ahorro acumulado</div>
                <div style="font-size: 2rem; font-weight: 900;" class="tabular">$21,236</div>
                <div style="font-size: 0.85rem; opacity: 0.9; margin-top: 0.35rem;">vs auto gasolina equivalente</div>
            </div>
        </div>
    </div>
</section>

<!-- ============== POR QUÉ AHORRAS ============== -->
<section class="section" id="por-que">
    <div class="section-head center">
        <div class="eyebrow">Por qué ahorras</div>
        <h2>4 razones por las que un BYD cuesta menos cada mes</h2>
        <p class="lead">El ahorro no es solo en la "gasolina". Cada parte del costo de tener un auto se reduce — y aquí te lo explicamos sin letra chica.</p>
    </div>

    <div class="reasons">
        <div class="reason">
            <div class="reason-icon"><i class="fas fa-bolt"></i></div>
            <h3>Energía más barata</h3>
            <p>Recargar electricidad en casa cuesta una fracción de lo que gastas en gasolina. Cargar de 0 a 100% tu BYD puede salir por menos de $100 con tarifa CFE residencial.</p>
            <span class="savings-tag">−70% a −85% por km</span>
        </div>
        <div class="reason">
            <div class="reason-icon"><i class="fas fa-tools"></i></div>
            <h3>Sin afinaciones ni aceite</h3>
            <p>Un motor eléctrico tiene una decena de piezas móviles vs cientos en uno de combustión. Olvídate de afinaciones, cambios de aceite, bujías, filtros, banda de tiempo.</p>
            <span class="savings-tag">~$8,000/año menos</span>
        </div>
        <div class="reason">
            <div class="reason-icon"><i class="fas fa-undo-alt"></i></div>
            <h3>Frenos que duran el doble</h3>
            <p>El sistema de frenado regenerativo desgasta mucho menos las balatas. Recuperas energía cada vez que frenas, y los cambios se hacen al doble de tiempo.</p>
            <span class="savings-tag">+100% vida útil</span>
        </div>
        <div class="reason">
            <div class="reason-icon"><i class="fas fa-shield-alt"></i></div>
            <h3>Garantía de batería 8 años</h3>
            <p>BYD garantiza la batería Blade por 8 años o 160,000 km. La tecnología LFP (litio-ferrofosfato) está diseñada para durar más de 1,000,000 km manteniendo su capacidad.</p>
            <span class="savings-tag">8 años cobertura</span>
        </div>
    </div>
</section>

<!-- ============== COMPARATIVA ============== -->
<section class="compare" id="comparativa">
    <div class="compare-inner">
        <div class="section-head center">
            <div class="eyebrow" style="color: #6ee7b7;">La cuenta del King en 17,220 km</div>
            <h2>Lo que realmente cuesta · y lo que habría costado</h2>
            <p class="lead">Tomamos los números crudos del dashboard del King y los comparamos contra un auto de gasolina equivalente (12 km/L Magna) para los mismos 17,220 km.</p>
        </div>

        <div class="compare-grid">
            <div class="compare-card gas">
                <span class="tag">SI FUERA GASOLINA</span>
                <h4>Gasto en 17,220 km</h4>
                <div class="big tabular">$34,099</div>
                <p class="desc">1,435 L de Magna a $23.76</p>
                <ul>
                    <li><i class="fas fa-circle"></i> 1,435 L de gasolina</li>
                    <li><i class="fas fa-circle"></i> Rendimiento ~12 km/L</li>
                    <li><i class="fas fa-circle"></i> Sin contar afinaciones</li>
                </ul>
            </div>
            <div class="compare-card byd">
                <span class="tag">REAL · MI KING</span>
                <h4>Gasto en 17,220 km</h4>
                <div class="big tabular">$12,863</div>
                <p class="desc">308.2 L combustible + 1,582.9 kWh</p>
                <ul>
                    <li><i class="fas fa-circle"></i> Solo 308.2 L gasolina</li>
                    <li><i class="fas fa-circle"></i> 1,582.9 kWh recargados</li>
                    <li><i class="fas fa-circle"></i> Promedio 1.8 L/100 km</li>
                </ul>
            </div>
            <div class="compare-card saving">
                <span class="tag">AHORRO REAL</span>
                <h4>Lo que ya me ahorré</h4>
                <div class="big tabular">$21,236</div>
                <p class="desc">62% menos · $1.23 ahorrado por km</p>
                <ul>
                    <li><i class="fas fa-check-circle"></i> Datos del dashboard, no estimaciones</li>
                    <li><i class="fas fa-check-circle"></i> Sin contar mantenimiento</li>
                    <li><i class="fas fa-check-circle"></i> Y seguirá creciendo</li>
                </ul>
            </div>
        </div>

        <div class="compare-timeline">
            <div class="timeline-item"><div class="period">Por km</div><div class="amount tabular">$1.23</div></div>
            <div class="timeline-item"><div class="period">17,220 km</div><div class="amount tabular">$21,236</div></div>
            <div class="timeline-item"><div class="period">A 30,000 km</div><div class="amount tabular">$36,990</div></div>
            <div class="timeline-item"><div class="period">A 100,000 km</div><div class="amount tabular">$123,300</div></div>
            <div class="timeline-item"><div class="period">A 160,000 km</div><div class="amount tabular">$197,280</div></div>
        </div>

        <p style="text-align: center; color: var(--muted-2); font-size: 0.85rem; margin-top: 2rem; max-width: 700px; margin-left: auto; margin-right: auto;">
            <i class="fas fa-info-circle"></i> Cálculo: 308.2 L × $23.76 + 1,582.9 kWh × $3.50 (tarifa CFE promedio) = $12,863. Auto comparativo a 12 km/L: 17,220 / 12 × $23.76 = $34,099.
        </p>
    </div>
</section>

<!-- ============== CASOS ============== -->
<section class="section">
    <div class="section-head center">
        <div class="eyebrow">Casos típicos en Monterrey</div>
        <h2>Cuánto ahorra cada tipo de conductor</h2>
        <p class="lead">Ejemplos calculados con precios de Magna a $<%= gasPrices.magna %>/L y tarifa CFE residencial promedio.</p>
    </div>

    <div class="cases">
        <div class="case-card">
            <div class="case-avatar"><i class="fas fa-briefcase"></i></div>
            <div>
                <div class="case-name">Carlos · Oficinista</div>
                <div class="case-meta">Casa → oficina, 800 km/mes</div>
            </div>
            <p style="color: var(--muted); font-size: 0.95rem;">Trayectos cortos, rendimiento bajo por tráfico. Carga el auto en casa cada 3 días.</p>
            <div class="case-savings">
                <div class="num tabular">$1,160<small style="font-size:0.85rem; font-weight:500;">/mes</small></div>
                <div class="lbl">≈ $13,920 al año</div>
            </div>
        </div>

        <div class="case-card">
            <div class="case-avatar"><i class="fas fa-motorcycle"></i></div>
            <div>
                <div class="case-name">Mariana · Vendedora</div>
                <div class="case-meta">Visitas a clientes, 2,500 km/mes</div>
            </div>
            <p style="color: var(--muted); font-size: 0.95rem;">Mucho recorrido diario. Carga combinada en casa y en estaciones públicas BYD.</p>
            <div class="case-savings">
                <div class="num tabular">$3,640<small style="font-size:0.85rem; font-weight:500;">/mes</small></div>
                <div class="lbl">≈ $43,680 al año</div>
            </div>
        </div>

        <div class="case-card">
            <div class="case-avatar"><i class="fas fa-users"></i></div>
            <div>
                <div class="case-name">Familia García</div>
                <div class="case-meta">Auto familiar, 1,800 km/mes</div>
            </div>
            <p style="color: var(--muted); font-size: 0.95rem;">Escuela, super, fines de semana fuera. Eligen BYD Song Plus por espacio.</p>
            <div class="case-savings">
                <div class="num tabular">$2,620<small style="font-size:0.85rem; font-weight:500;">/mes</small></div>
                <div class="lbl">≈ $31,440 al año</div>
            </div>
        </div>
    </div>
</section>

<!-- ============== MODELOS ============== -->
<section class="section" id="modelos">
    <div class="section-head center">
        <div class="eyebrow">Modelos disponibles</div>
        <h2>Cualquier BYD te ahorra dinero</h2>
        <p class="lead">Compactos urbanos, SUVs familiares, pickups híbridas — todos comparten la misma tecnología de ahorro.</p>
    </div>

    <div class="models-strip">
        <% vehicles.slice(0, 6).forEach(function(v){ %>
            <a href="/calculatusahorros" class="model-pill">
                <img src="<%= v.image %>" alt="<%= v.displayName %>">
                <div class="nm"><%= v.displayName %></div>
                <% if (v.type === 'electric') { %>
                    <span class="ty electric"><i class="fas fa-bolt"></i> Eléctrico</span>
                <% } else { %>
                    <span class="ty hybrid"><i class="fas fa-charging-station"></i> Híbrido</span>
                <% } %>
                <div class="save">Ahorra hasta $3,200/mes</div>
            </a>
        <% }); %>
    </div>
    <p style="text-align: center; margin-top: 2rem; color: var(--muted);">
        <a href="/calculatusahorros" style="color: var(--green); font-weight: 700; text-decoration: none;">
            Ver mi ahorro específico por modelo <i class="fas fa-arrow-right"></i>
        </a>
    </p>
</section>

<!-- ============== FAQ AHORRO ============== -->
<section class="section section-narrow">
    <div class="section-head center">
        <div class="eyebrow">Preguntas frecuentes</div>
        <h2>Dudas sobre el ahorro</h2>
    </div>

    <div class="faq-grid">
        <div class="faq-item">
            <h4><i class="fas fa-question-circle"></i> ¿Y la luz no me va a subir muchísimo?</h4>
            <p>Cargar un BYD usa entre 200 y 400 kWh/mes — equivalente a un refrigerador grande. Con tarifa básica CFE, la diferencia en tu recibo es mínima comparada con lo que ahorras en gasolina.</p>
        </div>
        <div class="faq-item">
            <h4><i class="fas fa-question-circle"></i> ¿Qué pasa si me quedo sin batería?</h4>
            <p>Los BYD eléctricos rinden de 400 a 700 km por carga. Los híbridos enchufables (PHEV) tienen además respaldo de gasolina con autonomía total de más de 1,000 km.</p>
        </div>
        <div class="faq-item">
            <h4><i class="fas fa-question-circle"></i> ¿La batería se desgasta y pierdo dinero?</h4>
            <p>La batería BYD Blade (LFP) mantiene >80% de capacidad después de 8 años. BYD la garantiza por 8 años o 160,000 km. Está hecha para durar más que el resto del auto.</p>
        </div>
        <div class="faq-item">
            <h4><i class="fas fa-question-circle"></i> ¿Necesito instalar algo en mi casa?</h4>
            <p>Para uso normal, un contacto 220V (como el de la secadora) es suficiente. Si quieres carga rápida en casa, instalas un cargador wallbox — Salma te ayuda con la cotización.</p>
        </div>
    </div>
</section>

<!-- ============== PROMOCIONES ACTIVAS ============== -->
<% if (typeof promocionesActivas !== 'undefined' && promocionesActivas.length > 0) { %>
<section class="section">
    <div class="section-head center">
        <div class="eyebrow">Promociones vigentes</div>
        <h2>Ofertas que mejoran tu ahorro</h2>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
        <% promocionesActivas.forEach(function(p){ %>
            <div style="background: white; border-radius: 16px; overflow: hidden; border: 2px solid <%= p.color_acento || '#059669' %>; box-shadow: var(--shadow-sm);">
                <% if (p.imagen) { %>
                    <img src="<%= p.imagen %>" alt="<%= p.titulo %>" style="width: 100%; aspect-ratio: 16/9; object-fit: cover;">
                <% } else { %>
                    <div style="height: 8px; background: <%= p.color_acento || '#059669' %>;"></div>
                <% } %>
                <div style="padding: 1.5rem;">
                    <h3 style="font-size: 1.2rem; font-weight: 800; margin-bottom: 0.5rem; color: <%= p.color_acento || '#059669' %>;"><%= p.titulo %></h3>
                    <% if (p.subtitulo) { %><p style="color: var(--muted); font-size: 0.95rem; margin-bottom: 1rem;"><%= p.subtitulo %></p><% } %>
                    <% if (p.descripcion) { %><p style="color: var(--ink-2); font-size: 0.92rem; margin-bottom: 1rem;"><%= p.descripcion %></p><% } %>
                    <% if (p.cta_url) { %>
                        <a href="<%= p.cta_url %>" style="background: <%= p.color_acento || '#059669' %>; color: white; padding: 0.6rem 1.1rem; border-radius: 8px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem;">
                            <%= p.cta_texto || 'Más información' %> <i class="fas fa-arrow-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>
</section>
<% } %>

<!-- ============== ENTREGAS RECIENTES ============== -->
<% if (typeof ultimasEntregas !== 'undefined' && ultimasEntregas.length > 0) { %>
<section class="section">
    <div class="section-head center">
        <div class="eyebrow"><i class="fas fa-camera"></i> Entregas gestionadas por Salma</div>
        <h2>Clientes reales · Autos entregados</h2>
        <p class="lead">Cada foto es una persona que confió en Salma y hoy maneja su BYD por Monterrey.</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem;">
        <% ultimasEntregas.forEach(function(e){ %>
            <article style="background: white; border-radius: 14px; overflow: hidden; border: 1px solid var(--line); box-shadow: var(--shadow-sm);">
                <div style="position: relative; aspect-ratio: 4/3; background: var(--bg); overflow: hidden;">
                    <img src="<%= e.foto_thumbnail || e.foto_principal %>" alt="<%= e.cliente_nombre %>" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
                    <span style="position: absolute; top: 0.65rem; right: 0.65rem; background: rgba(15,23,42,0.85); color: white; padding: 0.2rem 0.55rem; border-radius: 5px; font-size: 0.72rem; font-weight: 600;">
                        <%= e.modelo %>
                    </span>
                </div>
                <div style="padding: 1rem;">
                    <strong style="display: block; font-size: 0.98rem;"><%= e.cliente_nombre %></strong>
                    <% if (e.cliente_ciudad) { %>
                        <small style="color: var(--muted); font-size: 0.82rem;"><i class="fas fa-map-marker-alt"></i> <%= e.cliente_ciudad %></small>
                    <% } %>
                </div>
            </article>
        <% }) %>
    </div>
    <p style="text-align: center; margin-top: 2rem;">
        <a href="/entregas" style="color: var(--green); font-weight: 700; text-decoration: none;">
            Ver todas las entregas <i class="fas fa-arrow-right"></i>
        </a>
    </p>
</section>
<% } %>

<!-- ============== TESTIMONIOS ============== -->
<% if (typeof testimoniosDestacados !== 'undefined' && testimoniosDestacados.length > 0) { %>
<section class="section" style="background: var(--green-mint); border-radius: 24px; max-width: 1100px;">
    <div class="section-head center">
        <div class="eyebrow"><i class="fas fa-quote-left"></i> Lo dicen los clientes</div>
        <h2>Testimonios reales</h2>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem;">
        <% testimoniosDestacados.forEach(function(c){ %>
            <div style="background: white; border-radius: 14px; padding: 1.5rem; border: 1px solid var(--line);">
                <div style="color: var(--amber); margin-bottom: 0.75rem;">
                    <% for (let i = 0; i < (c.estrellas || 5); i++) { %><i class="fas fa-star"></i><% } %>
                </div>
                <p style="font-size: 0.98rem; margin-bottom: 1rem; color: var(--ink-2);">"<%= c.texto %>"</p>
                <div style="display: flex; justify-content: space-between; font-size: 0.85rem; align-items: center;">
                    <strong><%= c.nombre %></strong>
                    <% if (c.modelo_byd) { %><span style="color: var(--green-dark); font-size: 0.8rem;"><i class="fas fa-car"></i> <%= c.modelo_byd %></span><% } %>
                </div>
            </div>
        <% }) %>
    </div>
    <p style="text-align: center; margin-top: 2rem;">
        <a href="/comentarios" style="color: var(--green-dark); font-weight: 700; text-decoration: none;">
            Leer todos los testimonios o dejar el tuyo <i class="fas fa-arrow-right"></i>
        </a>
    </p>
</section>
<% } %>

<!-- ============== RINCÓN BYD CTA ============== -->
<section class="section" style="text-align: center; max-width: 800px;">
    <div class="eyebrow">Rincón BYD</div>
    <h2 style="font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 1rem;">¿Quieres saber más sobre BYD?</h2>
    <p style="color: var(--muted); margin-bottom: 2rem;">La historia, la tecnología Blade, garantías, modelos y todo lo que necesitas saber sobre el fabricante #1 de autos eléctricos en el mundo.</p>
    <a href="/que-es-byd" style="background: var(--ink); color: white; padding: 1rem 2rem; border-radius: 12px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
        Ir al Rincón BYD <i class="fas fa-arrow-right"></i>
    </a>
</section>

<!-- ============== CTA FINAL ============== -->
<section class="cta-final">
    <h2>Calcula tu ahorro exacto con Salma</h2>
    <p>Tu asesora BYD personal en Monterrey. Te ayudamos a elegir el modelo que más te ahorra según tu ruta diaria.</p>
    <div class="cta-buttons">
        <a href="#" class="wa" onclick="openWhatsApp(); return false;">
            <i class="fab fa-whatsapp"></i> Hablar con Salma
        </a>
        <a href="/calculatusahorros" class="calc">
            <i class="fas fa-calculator"></i> Calculadora completa
        </a>
    </div>
</section>

<!-- ============== FOOTER ============== -->
<footer>
    <div class="foot-row">
        <a href="#calculadora">Calculadora rápida</a>
        <a href="/calculatusahorros">Cálculo detallado</a>
        <a href="#por-que">Por qué ahorras</a>
        <a href="#modelos">Modelos</a>
        <a href="#" onclick="openWhatsApp(); return false;">Contacto</a>
    </div>
    <p style="margin-top: 1.5rem;">BYD Monterrey · Asesora Salma · Av. Las Américas Norte & Málaga, Guadalupe, N.L.</p>
    <p class="disclaimer">Los cálculos de ahorro son estimaciones referenciales basadas en precios de combustible y tarifas CFE actuales. El ahorro real depende del uso, ruta, modelo y condiciones de manejo. No constituye una oferta vinculante.</p>
</footer>

<!-- ============== SCRIPTS ============== -->
<script>
    // Constantes de cálculo
    const KWH_PRICE = 3.50;          // Tarifa CFE residencial promedio
    const EV_CONSUMPTION = 15;        // kWh/100km BYD eléctrico promedio
    const PHEV_FUEL = 1.8;            // L/100km PHEV (de la pantalla real)
    const PHEV_ELEC = 5.9;            // kWh/100km PHEV
    const GAS_PRICES = {
        magna: <%= gasPrices.magna %>,
        premium: <%= gasPrices.premium %>
    };

    // Formato MXN
    const fmt = n => Math.round(n).toLocaleString('es-MX');

    function calcularAhorro() {
        const km = parseFloat(document.getElementById('kmMes').value) || 0;
        const rend = parseFloat(document.getElementById('rendimiento').value) || 12;
        const tipoGas = document.getElementById('tipoGas').value;
        const tipoBYD = document.getElementById('tipoBYD').value;
        const gasPrice = GAS_PRICES[tipoGas];

        // Gasto actual con gasolina
        const litros = km / rend;
        const gastoGas = litros * gasPrice;

        // Gasto con BYD
        let gastoBYD;
        if (tipoBYD === 'electrico') {
            const kwh = (km / 100) * EV_CONSUMPTION;
            gastoBYD = kwh * KWH_PRICE;
        } else {
            // PHEV: asumimos 70% eléctrico, 30% gasolina
            const kmElec = km * 0.7;
            const kmGas = km * 0.3;
            const kwh = (kmElec / 100) * PHEV_ELEC;
            const litrosPHEV = (kmGas / 100) * PHEV_FUEL * 100 / 100; // simplificado
            const litrosPhevReal = (kmGas / 100) * 7; // motor combustión gasta ~7 L/100km cuando trabaja
            gastoBYD = (kwh * KWH_PRICE) + (litrosPhevReal * gasPrice);
        }

        const ahorroMes = Math.max(0, gastoGas - gastoBYD);
        const ahorroAnio = ahorroMes * 12;
        const ahorro5 = ahorroMes * 60;

        animarNumero('ahorroMes', ahorroMes);
        animarNumero('ahorroAnio', ahorroAnio);
        animarNumero('ahorro5', ahorro5);
    }

    // Animación de conteo
    function animarNumero(id, target) {
        const el = document.getElementById(id);
        const current = parseFloat((el.textContent || '0').replace(/,/g, '')) || 0;
        const diff = target - current;
        const steps = 20;
        const stepValue = diff / steps;
        let i = 0;
        clearInterval(el._timer);
        el._timer = setInterval(() => {
            i++;
            const val = current + (stepValue * i);
            el.textContent = fmt(val);
            if (i >= steps) { clearInterval(el._timer); el.textContent = fmt(target); }
        }, 25);
    }

    // Inputs reactivos
    ['kmMes','rendimiento','tipoGas','tipoBYD'].forEach(id => {
        document.getElementById(id).addEventListener('input', calcularAhorro);
        document.getElementById(id).addEventListener('change', calcularAhorro);
    });

    // Cálculo inicial
    calcularAhorro();

    // WhatsApp
    function openWhatsApp(modelo = '') {
        let mensaje = 'Hola Salma! Me interesa saber cuánto puedo ahorrar con un BYD.';
        if (modelo) mensaje = `Hola Salma! Me interesa el BYD ${modelo} y saber mi ahorro estimado.`;
        window.open(`https://wa.me/528120272752?text=${encodeURIComponent(mensaje)}`, '_blank');
    }

    function openWhatsAppConAhorro() {
        const km = document.getElementById('kmMes').value;
        const ahorroMes = document.getElementById('ahorroMes').textContent;
        const tipo = document.getElementById('tipoBYD').value === 'electrico' ? 'eléctrico' : 'híbrido enchufable';
        const mensaje = `Hola Salma! Calculé mi ahorro con un BYD ${tipo}: $${ahorroMes}/mes manejando ${km} km al mes. Quiero más información y cotización.`;
        window.open(`https://wa.me/528120272752?text=${encodeURIComponent(mensaje)}`, '_blank');
    }

    // Mobile menu
    const menuToggle = document.getElementById('menuToggle');
    const navLinks = document.getElementById('navLinks');
    menuToggle?.addEventListener('click', () => {
        navLinks.classList.toggle('open');
        menuToggle.innerHTML = navLinks.classList.contains('open')
            ? '<i class="fas fa-times"></i>'
            : '<i class="fas fa-bars"></i>';
    });
    navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        navLinks.classList.remove('open');
        menuToggle.innerHTML = '<i class="fas fa-bars"></i>';
    }));

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            const href = this.getAttribute('href');
            if (href === '#') return;
            const target = document.querySelector(href);
            if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
        });
    });
</script>

<script src="/js/chat-widget.js?v=2.0.1" defer></script>
<script src="/js/google-ads-tracking.js" defer></script>
</body>
</html>
